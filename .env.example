# ══════════════════════════════════════════════════════════════
# formularios.ia.br — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local — ele já está no .gitignore.
# ══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# SUPABASE — Banco de dados e autenticação
# ──────────────────────────────────────────────────────────────
# Onde encontrar: Supabase Dashboard → Project Settings → Database
# IMPORTANTE: Use a conexão DIRETA (porta 5432), não o pooler.
# URI formato: postgresql://postgres:[SENHA]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJECT-REF].supabase.co:5432/postgres"

# Onde encontrar: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[SEU-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Chave de serviço — NUNCA exponha no cliente (sem prefixo NEXT_PUBLIC_)
# Onde encontrar: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="eyJ..."


# ──────────────────────────────────────────────────────────────
# APP — URL base da aplicação
# ──────────────────────────────────────────────────────────────
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com.br
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ──────────────────────────────────────────────────────────────
# RESEND — Envio de e-mails transacionais
# ──────────────────────────────────────────────────────────────
# Crie uma conta em: https://resend.com
# Gere uma API key em: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# E-mail remetente — o domínio deve estar verificado no Resend
# Em desenvolvimento pode usar: onboarding@resend.dev
RESEND_FROM_EMAIL="noreply@seudominio.com.br"


# ──────────────────────────────────────────────────────────────
# GOOGLE SHEETS — Exportar respostas para planilhas
# ──────────────────────────────────────────────────────────────
# Onde encontrar: Google Cloud Console → APIs e Serviços → Credenciais
# Crie um OAuth Client ID do tipo "Aplicativo da Web".
GOOGLE_CLIENT_ID="seu-client-id-aqui.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret-aqui"
# Dev: http://localhost:3000/api/auth/google-sheets/callback
# Prod: https://formularios.ia.br/api/auth/google-sheets/callback
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google-sheets/callback"


# ──────────────────────────────────────────────────────────────
# IP_HASH_SALT — Anonimização de IPs (LGPD) — OBRIGATÓRIO em produção
# ──────────────────────────────────────────────────────────────
# Gere um valor aleatório seguro: openssl rand -hex 32
# IMPORTANTE: sem este valor em produção, o servidor rejeita todas as respostas.
# Nunca altere este valor após o deploy — invalida os hashes existentes para rate limiting.
IP_HASH_SALT="gere-com-openssl-rand-hex-32"


# ──────────────────────────────────────────────────────────────
# ABACATEPAY — Pagamentos PIX
# ──────────────────────────────────────────────────────────────
# Crie uma conta em: https://abacatepay.com
# Sandbox: use as chaves de teste enquanto a conta pro não for aprovada.
ABACATEPAY_API_KEY="sua-api-key-aqui"
ABACATEPAY_WEBHOOK_PUBLIC_KEY="sua-chave-publica-do-webhook"


# ──────────────────────────────────────────────────────────────
# SENTRY — Monitoramento de erros (opcional, mas recomendado em produção)
# ──────────────────────────────────────────────────────────────
# Crie um projeto em: https://sentry.io
# DSN: Sentry Dashboard → Settings → Projects → [projeto] → Client Keys (DSN)
# O NEXT_PUBLIC_ é necessário para capturar erros no browser também.
NEXT_PUBLIC_SENTRY_DSN="https://[chave]@[org].ingest.sentry.io/[projeto-id]"

# Necessário apenas no CI/CD para upload de source maps (opcional)
# SENTRY_ORG="sua-org"
# SENTRY_PROJECT="formularios-app"
# SENTRY_AUTH_TOKEN="sntrys_..."
